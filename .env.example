# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# LLM Provider (Groq / OpenAI-compatible)
LLM_API_KEY=your-llm-api-key
LLM_MODEL=qwen/qwen3-32b
LLM_BASE_URL=https://api.groq.com/openai/v1/chat/completions

# Owner number (digits only, used as initial admin seed)
OWNER_NUMBER=1234567890

# Active salon slug
ACTIVE_SALON_SLUG=demo_salon_1

# Server port
PORT=3000

# Chromium / WhatsApp Web tuning (important for small VPS)
CHROME_PATH=/usr/bin/google-chrome
WA_BROWSER_TIMEOUT_MS=180000
WA_PROTOCOL_TIMEOUT_MS=180000
WA_SINGLE_PROCESS=0

# Telegram notifications (optional — alerts skip if not set)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id
